@{
    ViewData["Title"] = "Buat Kontrak Baru";
}

<h2>Buat Kontrak Baru</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label for="kontrakNo">Nomor Kontrak</label>
        <input type="text" class="form-control" id="kontrakNo" name="kontrakNo" required />
    </div>
    <div class="form-group">
        <label for="clientName">Nama Client</label>
        <input type="text" class="form-control" id="clientName" name="clientName" required />
    </div>
    <div class="form-group">
        <label for="otr">Harga OTR</label>
        <input type="number" class="form-control" id="otr" name="otr" required />
    </div>
    <div class="form-group">
        <label for="dp">DP (%)</label>
        <input type="number" class="form-control" id="dp_percen" name="dp_percen" required />
    </div>
    <div class="form-group">
        <label for="jangkaWaktu">Jangka Waktu (bulan)</label>
        <input type="number" class="form-control" id="jangkaWaktu" name="jangkaWaktu" required />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Simpan</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Batal</a>
</form>
